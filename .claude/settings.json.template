    "allow": [
      "Bash([npm test])",
      "Bash([npm run lint])",
      "Bash([npm run dev])",
      "Bash([npm run build])",
      "Bash([npm run format])",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git add)",
